<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Para ti 💚</title>

<style>
body {
    margin: 0;
    overflow: hidden;
    font-family: Arial, sans-serif;
    background: black;
}

/* BOTÓN */
#btnFinal {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    
    padding: 12px 25px;
    border-radius: 25px;
    border: none;
    
    background: rgba(0,0,0,0.5);
    color: white;
    
    font-size: 16px;
    cursor: pointer;
    
    backdrop-filter: blur(10px);
    transition: 0.3s;
    z-index: 10;
}

#btnFinal:hover {
    background: rgba(255,255,255,0.2);
}

/* MENSAJE */
#mensaje {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 30px;
    text-align: center;
    display: none;
    z-index: 10;
}
</style>
</head>

<body>

<audio id="music" loop>
    <source src="feid.mp3" type="audio/mpeg">
</audio>

<div id="mensaje">Solo quería que vieras esto... 💚</div>

<button id="btnFinal">Haz clic aquí 💚</button>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/examples/js/controls/OrbitControls.js"></script>

<script>

// 🔒 VERIFICAR THREE
if(typeof THREE === "undefined"){
    alert("Error cargando Three.js. Revisa conexión.");
}

// 🎬 ESCENA
let scene = new THREE.Scene();

let camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.set(0, 2, 15);

let renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);

// 🎮 CONTROLES
let controls = new THREE.OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.enablePan = false;

// 🌌 FONDO (con fallback)
let loader = new THREE.TextureLoader();
loader.load(
    "fondo.jpg",
    function(texture){
        texture.encoding = THREE.sRGBEncoding;
        scene.background = texture;
    },
    undefined,
    function(){
        console.log("No se pudo cargar fondo");
        scene.background = new THREE.Color(0x000000);
    }
);

// 💡 LUCES
scene.add(new THREE.AmbientLight(0x404080, 0.6));

let moonLight = new THREE.DirectionalLight(0x6699ff, 0.7);
moonLight.position.set(0,5,5);
scene.add(moonLight);

let magicLight = new THREE.PointLight(0xff66cc,1,20);
magicLight.position.set(0,2,2);
scene.add(magicLight);

// 🌊 LAGO
let water = new THREE.Mesh(
    new THREE.PlaneGeometry(50,20),
    new THREE.MeshBasicMaterial({
        color:0x001e2b,
        transparent:true,
        opacity:0.6
    })
);
water.rotation.x = -Math.PI/2;
water.position.y = -4.5;
scene.add(water);

// 🌸 FLORES (seguras)
let flowers = [];
loader.load("flor.png", function(tex){

    for(let i=0;i<12;i++){
        let mat = new THREE.MeshStandardMaterial({
            map: tex,
            transparent:true,
            emissive: new THREE.Color(0x220033),
            emissiveIntensity:0.5
        });

        let f = new THREE.Mesh(new THREE.PlaneGeometry(1,1), mat);

        f.rotation.x = -Math.PI/2;
        f.position.set(Math.random()*8-4,-4.3,Math.random()*2);

        scene.add(f);
        flowers.push(f);
    }

});

// ✨ LUCIÉRNAGAS
let fireflies = [];

for(let i=0;i<50;i++){
    let mesh = new THREE.Mesh(
        new THREE.SphereGeometry(0.03),
        new THREE.MeshBasicMaterial({color:0xffcc66})
    );

    let light = new THREE.PointLight(0xffaa66,0.5,3);

    mesh.position.set(Math.random()*10-5,Math.random()*5,Math.random()*5);

    scene.add(mesh);
    scene.add(light);

    fireflies.push({mesh,light});
}

// ⭐ ESTRELLAS CONTROLADAS
let puedeCrear = true;

function crearEstrella(){
    if(!puedeCrear) return;
    puedeCrear=false;

    let star = new THREE.Mesh(
        new THREE.SphereGeometry(0.05),
        new THREE.MeshBasicMaterial({color:0xffffff})
    );

    star.position.set(-8,Math.random()*4,-2);
    scene.add(star);

    function anim(){
        star.position.x+=0.08;
        star.position.y-=0.03;

        if(star.position.x<8){
            requestAnimationFrame(anim);
        } else {
            scene.remove(star);
            setTimeout(()=>puedeCrear=true,1500);
        }
    }
    anim();
}

setInterval(crearEstrella,2000);

// 💚 CORAZONES
function crearCorazon(){
    let h = document.createElement("div");
    h.innerText="💚";

    h.style.position="absolute";
    h.style.left=Math.random()*100+"vw";
    h.style.bottom="-50px";
    h.style.fontSize=(20+Math.random()*20)+"px";

    document.body.appendChild(h);

    let pos=-50;

    function subir(){
        pos+=0.5;
        h.style.bottom=pos+"px";

        if(pos<window.innerHeight){
            requestAnimationFrame(subir);
        } else {
            h.remove();
        }
    }
    subir();
}

setInterval(crearCorazon,1500);

// 💬 FRASES
let frases=[
"Perdón por lo que hice...",
"No dejo de pensar en ti 💚",
"Me haces falta...",
"Quiero hacerlo mejor..."
];

function crearFrase(){
    let d=document.createElement("div");
    d.innerText=frases[Math.floor(Math.random()*frases.length)];

    d.style.position="absolute";
    d.style.bottom="0px";
    d.style.left=Math.random()*80+"%";
    d.style.color="white";

    document.body.appendChild(d);

    let pos=0;

    function subir(){
        pos+=0.3;
        d.style.bottom=pos+"px";

        if(pos<window.innerHeight){
            requestAnimationFrame(subir);
        } else {
            d.remove();
        }
    }
    subir();
}

setInterval(crearFrase,4000);

// 🎬 ENTRADA
let start=Date.now();

function entrada(){
    let t=(Date.now()-start)/3000;
    let ease=1-Math.pow(1-Math.min(t,1),3);

    camera.position.z=15-(10*ease);
    camera.position.y=2-(1*ease);

    if(t<1) requestAnimationFrame(entrada);
}
entrada();

// 🔘 BOTÓN
document.getElementById("btnFinal").onclick=()=>{
    document.getElementById("mensaje").style.display="block";

    let music=document.getElementById("music");
    if(music) music.play();
};

// 🔄 LOOP
function animate(){
    requestAnimationFrame(animate);

    controls.update();

    flowers.forEach((f,i)=>{
        f.rotation.z+=0.01;
        f.position.y+=Math.sin(Date.now()*0.001+i)*0.001;
    });

    fireflies.forEach((f,i)=>{
        let t=Date.now()*0.001+i;
        let intensity=Math.abs(Math.sin(t*2));

        f.mesh.material.opacity=intensity;
        f.light.intensity=intensity;
    });

    renderer.render(scene,camera);
}

animate();

// 📱 RESPONSIVE
window.addEventListener("resize",()=>{
    camera.aspect=window.innerWidth/window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth,window.innerHeight);
});

</script>

</body>
</html>
